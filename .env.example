# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# Blockchain RPC URL (Localhost: 8545, Amoy: https://rpc-amoy.polygon.technology)
NEXT_PUBLIC_RPC_URL=http://localhost:8545

# Voting System Contract Address
NEXT_PUBLIC_VOTING_SYSTEM_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Block Explorer base URL (no trailing slash). Examples: https://amoy.polygonscan.com, https://sepolia.etherscan.io
NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://amoy.polygonscan.com

# Block number when the VotingSystem contract was first deployed.
# Setting this avoids scanning from block 0 and speeds up tx hash lookups significantly.
# Find it on Etherscan/Polygonscan on the contract's page.
NEXT_PUBLIC_CONTRACT_DEPLOY_BLOCK=0
